{
  "name": "estoqueguard-offline",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "node --test scripts/tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "audit:i18n": "node scripts/i18n-audit.mjs",
    "audit:release": "node scripts/release-audit.mjs && npm run audit:i18n && npm run test && npm run typecheck"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.36",
    "expo-application": "~7.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.9",
    "expo-print": "~15.0.8",
    "expo-router": "^6.0.0",
    "expo-screen-capture": "~8.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-tracking-transparency": "~6.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.4.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/react": "~19.1.8",
    "babel-preset-expo": "~54.0.11",
    "typescript": "~5.9.2"
  }
