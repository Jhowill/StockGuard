{
  "expo": {
    "name": "EstoqueGuard Offline",
    "slug": "estoqueguard-offline",
    "scheme": "estoqueguard",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-localization"
    ]
  }
}
