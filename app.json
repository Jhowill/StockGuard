{
  "expo": {
    "name": "EstoqueGuard Offline",
    "slug": "estoqueguard-offline",
    "scheme": "estoqueguard",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./icons/android/expo/icon.png",
    "splash": {
      "image": "./icons/android/expo/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F14"
    },
    "android": {
      "package": "com.jhowill.stockguard",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./icons/android/expo/adaptive-icon-foreground.png",
        "backgroundImage": "./icons/android/expo/adaptive-icon-background.png"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.jhowill.stockguard",
      "buildNumber": "1",
      "icon": "./icons/ios/store/appstore_icon_1024.png",
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use o Face ID para proteger o acesso ao seu estoque.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./icons/android/expo/icon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-localization",
      "expo-document-picker",
      "expo-image-picker",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use o Face ID para proteger o acesso ao seu estoque."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4042606302261972~8243870370",
          "iosAppId": "ca-app-pub-4042606302261972~4321735996",
          "delayAppMeasurementInit": true,
          "userTrackingUsageDescription": "Sua permissao permite medir anuncios e manter recursos secundarios gratuitos."
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Sua permissao permite medir anuncios e manter recursos secundarios gratuitos."
        }
      ]
    ],
    "extra": {
      "EXPO_PUBLIC_ADS_ENABLED": "true",
      "EXPO_PUBLIC_ADS_TEST_MODE": "false",
      "EXPO_PUBLIC_ADMOB_ANDROID_APP_ID": "ca-app-pub-4042606302261972~8243870370",
      "EXPO_PUBLIC_ADMOB_IOS_APP_ID": "ca-app-pub-4042606302261972~4321735996",
      "EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_ID": "ca-app-pub-4042606302261972/8766614555",
      "EXPO_PUBLIC_ADMOB_IOS_REWARDED_ID": "ca-app-pub-4042606302261972/3646149813",
      "EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_INTERSTITIAL_ID": "ca-app-pub-4042606302261972/3204095443",
      "EXPO_PUBLIC_ADMOB_IOS_REWARDED_INTERSTITIAL_ID": "ca-app-pub-4042606302261972/7453532884"
    }
  }
}
